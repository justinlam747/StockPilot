<h2>Low Stock Alert</h2>
<p><strong><%= @shop.shop_domain %></strong> &mdash; <%= @flagged_variants.size %> item<%= @flagged_variants.size == 1 ? '' : 's' %> need attention:</p>

<table>
  <thead>
    <tr>
      <th>SKU</th>
      <th>Product / Variant</th>
      <th>Available</th>
      <th>Threshold</th>
      <th>Status</th>
    </tr>
  </thead>
  <tbody>
    <% @flagged_variants.each do |fv| %>
      <tr>
        <td><%= fv[:variant].sku %></td>
        <td><%= fv[:variant].product.title %> &mdash; <%= fv[:variant].title %></td>
        <td><%= fv[:available] %></td>
        <td><%= fv[:threshold] %></td>
        <td><%= fv[:status].to_s.titleize %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<p style="margin-top: 16px; color: #6D7175; font-size: 13px;">
  This alert was generated by StockPilot. Log in to your Shopify admin to take action.
</p>
