<h2>Low Stock Alert — <%= @shop.shop_domain %></h2>

<p><%= @flagged_variants.size %> item(s) need attention:</p>

<table border="1" cellpadding="8" cellspacing="0" style="border-collapse: collapse; width: 100%;">
  <thead>
    <tr style="background: #F6F6F7;">
      <th>SKU</th>
      <th>Product / Variant</th>
      <th>Available</th>
      <th>Threshold</th>
      <th>Status</th>
    </tr>
  </thead>
  <tbody>
    <% @flagged_variants.each do |fv| %>
      <tr>
        <td><%= fv[:variant].sku %></td>
        <td><%= fv[:variant].product.title %> — <%= fv[:variant].title %></td>
        <td><%= fv[:available] %></td>
        <td><%= fv[:threshold] %></td>
        <td><%= fv[:status].to_s.titleize %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<p style="margin-top: 16px; color: #6D7175;">
  This alert was generated by Inventory Intelligence. Log in to your Shopify admin to take action.
</p>
