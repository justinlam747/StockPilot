<%# ═══════════════════════════════════════════════════════════
     Section 3 — Big Statement
     ═══════════════════════════════════════════════════════════ %>
<section class="lp-statement">
  <h2 class="lp-statement__text" data-animate="words">
    Never lose a sale to an empty shelf.
  </h2>
</section>

<%# ═══════════════════════════════════════════════════════════
     Section 4 — Feature Bento Grid
     ═══════════════════════════════════════════════════════════ %>
<section class="lp-features">
  <div class="lp-features__header" data-animate="fade">
    <span class="lp-label">Capabilities</span>
    <h2 class="lp-section-title">Everything runs on autopilot</h2>
  </div>

  <div class="lp-bento">
    <div class="lp-bento__card lp-bento__card--lg" data-animate="card">
      <span class="lp-bento__label">Monitoring</span>
      <h3 class="lp-bento__title">Low-Stock Alerts</h3>
      <p class="lp-bento__desc">Watches every SKU in real time. When stock drops below your thresholds, you get notified instantly — before customers notice.</p>
      <div class="lp-bento__visual">
        <div class="lp-bento__bar-group">
          <div class="lp-bento__bar" style="--bar-w:85%"><span>Cotton Tee — 847</span></div>
          <div class="lp-bento__bar lp-bento__bar--warn" style="--bar-w:22%"><span>Denim Jacket — 12</span></div>
          <div class="lp-bento__bar" style="--bar-w:64%"><span>Canvas Bag — 391</span></div>
        </div>
      </div>
    </div>

    <div class="lp-bento__card" data-animate="card">
      <span class="lp-bento__label">AI</span>
      <h3 class="lp-bento__title">Purchase Order Drafts</h3>
      <p class="lp-bento__desc">Drafts purchase orders from low-stock signals and supplier lead times. Review, approve, send.</p>
    </div>

    <div class="lp-bento__card" data-animate="card">
      <span class="lp-bento__label">Reports</span>
      <h3 class="lp-bento__title">Weekly Digests</h3>
      <p class="lp-bento__desc">Trend analysis delivered every Monday. Timezone-aware scheduling, zero configuration.</p>
    </div>

    <div class="lp-bento__card lp-bento__card--lg" data-animate="card">
      <span class="lp-bento__label">Operations</span>
      <h3 class="lp-bento__title">Supplier Management</h3>
      <p class="lp-bento__desc">Track lead times, contacts, and order history for every supplier in one place. No more spreadsheets.</p>
      <div class="lp-bento__visual">
        <div class="lp-bento__supplier-row">
          <span class="lp-bento__avatar">TC</span>
          <span class="lp-bento__supplier-name">TextileCo Ltd</span>
          <span class="lp-bento__lead-time">14d lead</span>
        </div>
        <div class="lp-bento__supplier-row">
          <span class="lp-bento__avatar">PD</span>
          <span class="lp-bento__supplier-name">PackDirect Inc</span>
          <span class="lp-bento__lead-time">7d lead</span>
        </div>
      </div>
    </div>

    <div class="lp-bento__card" data-animate="card">
      <span class="lp-bento__label">Intelligence</span>
      <h3 class="lp-bento__title">Customer DNA</h3>
      <p class="lp-bento__desc">Profiles built from order history. Know who buys what, when, and why.</p>
    </div>

    <div class="lp-bento__card" data-animate="card">
      <span class="lp-bento__label">Compliance</span>
      <h3 class="lp-bento__title">GDPR Built In</h3>
      <p class="lp-bento__desc">Automatic handling of data requests and redaction webhooks. Privacy by design.</p>
    </div>
  </div>
</section>

<%# ═══════════════════════════════════════════════════════════
     Section 5 — How It Works
     ═══════════════════════════════════════════════════════════ %>
<section class="lp-steps">
  <div class="lp-steps__header" data-animate="fade">
    <span class="lp-label">How it works</span>
    <h2 class="lp-section-title">Three steps to autopilot</h2>
  </div>

  <div class="lp-steps__row">
    <div class="lp-step" data-animate="step">
      <div class="lp-step__number">1</div>
      <h3 class="lp-step__title">Connect</h3>
      <p class="lp-step__desc">Install the app and sync your Shopify store in one click. We pull your products, variants, and inventory levels.</p>
    </div>

    <div class="lp-step__connector" data-animate="connector"></div>

    <div class="lp-step" data-animate="step">
      <div class="lp-step__number">2</div>
      <h3 class="lp-step__title">Configure</h3>
      <p class="lp-step__desc">Set stock thresholds per variant, add your suppliers, and choose your alert channels. Five minutes, tops.</p>
    </div>

    <div class="lp-step__connector" data-animate="connector"></div>

    <div class="lp-step" data-animate="step">
      <div class="lp-step__number">3</div>
      <h3 class="lp-step__title">Autopilot</h3>
      <p class="lp-step__desc">StockPilot monitors inventory, fires alerts, drafts purchase orders, and generates reports — while you sleep.</p>
    </div>
  </div>
</section>

