  <div class="lp-cta__inner" data-animate="fade">
    <h2 class="lp-cta__title">Ready to put your inventory on autopilot?</h2>
    <p class="lp-cta__sub">Join Shopify merchants who never worry about stock again.</p>
    <a href="#shopify-connect" id="cta-get-started-btn" class="lp-cta__btn">Get Started</a>
