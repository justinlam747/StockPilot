    <h1 class="lp-hero__title" data-animate="hero">AI inventory<br>agents for<br>your store</h1>

    <p class="lp-hero__desc" data-animate="hero">
      Monitors every SKU. Fires alerts when stock runs low. Drafts purchase orders to your suppliers. Generates weekly inventory reports. All automatic.
    </p>

    <div class="lp-hero__buttons" data-animate="hero" id="shopify-connect">
      <%= form_with url: '/auth/shopify',
                    method: :post,
                    local: true,
                    data: { turbo: false },
                    html: { class: 'lp-shopify-form' } do %>
        <label for="shop-domain" class="sr-only">Shopify store domain</label>
        <%= text_field_tag :shop,
                           params[:shop],
                           id: 'shop-domain',
                           class: 'lp-shopify-form__input',
                           placeholder: 'your-store or your-store.myshopify.com',
                           required: true,
                           autocomplete: 'off',
                           spellcheck: false %>
        <%= submit_tag 'Connect Shopify', class: 'lp-btn--primary' %>
      <% end %>
    </div>
    <p class="lp-shopify-form__hint" data-animate="hero">
      Enter your Shopify subdomain. We normalize <code>your-store</code> to <code>your-store.myshopify.com</code>.
    </p>
  </div>

  <div class="lp-hero__right">
    <div class="lp-hero__dashboard" data-animate="hero-dashboard">
      <div class="lp-dash__chrome">
        <span class="lp-dash__dot"></span>
        <span class="lp-dash__dot"></span>
        <span class="lp-dash__dot"></span>
        <span class="lp-dash__url">app.stockpilot.io/dashboard</span>
      </div>
      <div class="lp-dash__body">
        <div class="lp-dash__stats">
          <div class="lp-dash__stat">
            <span class="lp-dash__stat-label">Low Stock</span>
            <span class="lp-dash__stat-value lp-dash__stat-value--alert">12</span>
          </div>
          <div class="lp-dash__stat">
            <span class="lp-dash__stat-label">Total SKUs</span>
            <span class="lp-dash__stat-value">2,847</span>
          </div>
          <div class="lp-dash__stat">
            <span class="lp-dash__stat-label">PO Drafts</span>
            <span class="lp-dash__stat-value lp-dash__stat-value--green">3</span>
          </div>
        </div>
        <div class="lp-dash__chart"></div>
        <div class="lp-dash__rows">
          <div class="lp-dash__row">
            <span class="lp-dash__row-name"></span>
            <span class="lp-dash__row-bar" style="width:72%"></span>
            <span class="lp-dash__row-num"></span>
          </div>
          <div class="lp-dash__row">
            <span class="lp-dash__row-name"></span>
            <span class="lp-dash__row-bar lp-dash__row-bar--low" style="width:18%"></span>
            <span class="lp-dash__row-num"></span>
          </div>
          <div class="lp-dash__row">
            <span class="lp-dash__row-name"></span>
            <span class="lp-dash__row-bar" style="width:55%"></span>
            <span class="lp-dash__row-num"></span>
          </div>
          <div class="lp-dash__row">
            <span class="lp-dash__row-name"></span>
            <span class="lp-dash__row-bar" style="width:89%"></span>
            <span class="lp-dash__row-num"></span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

