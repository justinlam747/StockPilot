<%# ═══════════════════════════════════════════════════════════
     Section 7 — Testimonial
     ═══════════════════════════════════════════════════════════ %>
<section class="lp-testimonial" data-animate="fade">
  <div class="lp-testimonial__inner">
    <div class="lp-testimonial__quote">&ldquo;</div>
    <blockquote class="lp-testimonial__text">
      We used to spend four hours a week manually checking stock levels. StockPilot cut that to zero. The AI purchase orders alone saved us from three stockouts last month.
    </blockquote>
    <div class="lp-testimonial__author">
      <div class="lp-testimonial__avatar">JM</div>
      <div>
        <div class="lp-testimonial__name">Jordan Mitchell</div>
        <div class="lp-testimonial__role">Operations Lead, Threadbare Goods</div>
      </div>
    </div>
  </div>
</section>

<%# ═══════════════════════════════════════════════════════════
     Section 8 — CTA Footer
     ═══════════════════════════════════════════════════════════ %>
