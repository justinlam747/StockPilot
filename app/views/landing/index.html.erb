<section class="lp-hero">
  <div class="lp-hero__left">
    <div class="lp-hero__brand" data-animate="hero">catalog audit</div>

    <div class="lp-hero__pill" data-animate="hero">
      <span>Shopify</span>
      <span class="lp-hero__pill-sep"></span>
      <span>Rails</span>
      <span class="lp-hero__pill-sep"></span>
      <span>Lean workflow</span>
    </div>

    <h1 class="lp-hero__title" data-animate="hero">Find catalog issues before they hurt conversion.</h1>

    <p class="lp-hero__desc" data-animate="hero">
      Connect a Shopify store, run one sync, and review the product issues that matter: missing images, duplicate SKUs, empty metadata, and inconsistent catalog quality.
    </p>

    <div class="lp-hero__buttons" data-animate="hero">
      <a href="/settings" class="lp-btn--primary">Start audit</a>
      <a href="/dashboard" class="lp-btn--secondary">Open dashboard</a>
    </div>
  </div>

  <div class="lp-hero__right">
    <div class="lp-hero__dashboard" data-animate="hero-dashboard">
      <div class="lp-dash__chrome">
        <span class="lp-dash__dot"></span>
        <span class="lp-dash__dot"></span>
        <span class="lp-dash__dot"></span>
        <span class="lp-dash__url">catalog-audit/dashboard</span>
      </div>
      <div class="lp-dash__body">
        <div class="lp-dash__stats">
          <div class="lp-dash__stat">
            <span class="lp-dash__stat-label">Products</span>
            <span class="lp-dash__stat-value">1,247</span>
          </div>
          <div class="lp-dash__stat">
            <span class="lp-dash__stat-label">Issues</span>
            <span class="lp-dash__stat-value lp-dash__stat-value--alert">34</span>
          </div>
          <div class="lp-dash__stat">
            <span class="lp-dash__stat-label">Coverage</span>
            <span class="lp-dash__stat-value lp-dash__stat-value--green">91%</span>
          </div>
        </div>
        <div class="lp-dash__rows">
          <div class="lp-dash__row">
            <span class="lp-dash__row-name">Missing image</span>
            <span class="lp-dash__row-bar lp-dash__row-bar--low" style="width:30%"></span>
          </div>
          <div class="lp-dash__row">
            <span class="lp-dash__row-name">Duplicate SKU</span>
            <span class="lp-dash__row-bar lp-dash__row-bar--low" style="width:18%"></span>
          </div>
          <div class="lp-dash__row">
            <span class="lp-dash__row-name">Blank vendor</span>
            <span class="lp-dash__row-bar" style="width:42%"></span>
          </div>
          <div class="lp-dash__row">
            <span class="lp-dash__row-name">Zero price</span>
            <span class="lp-dash__row-bar" style="width:12%"></span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="lp-steps">
  <div class="lp-steps__header" data-animate="fade">
    <span class="lp-label">Workflow</span>
    <h2 class="lp-section-title">One task, one service, one obvious outcome</h2>
  </div>

  <div class="lp-steps__row">
    <div class="lp-step" data-animate="step">
      <div class="lp-step__number">1</div>
      <h3 class="lp-step__title">Connect</h3>
      <p class="lp-step__desc">Use Shopify OAuth to connect a store with the minimum required scope.</p>
    </div>

    <div class="lp-step__connector" data-animate="connector"></div>

    <div class="lp-step" data-animate="step">
      <div class="lp-step__number">2</div>
      <h3 class="lp-step__title">Sync</h3>
      <p class="lp-step__desc">Run a single sync job that pulls catalog data and computes the current audit issues.</p>
    </div>

    <div class="lp-step__connector" data-animate="connector"></div>

    <div class="lp-step" data-animate="step">
      <div class="lp-step__number">3</div>
      <h3 class="lp-step__title">Review</h3>
      <p class="lp-step__desc">Open the issues list and fix the catalog problems with the highest merchant impact.</p>
    </div>
  </div>
</section>
