<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>StockPilot</title>
  <%= stylesheet_link_tag "application" %>
  <%= stylesheet_link_tag "overrides" %>
  <script src="https://unpkg.com/htmx.org@2.0.4"></script>
  <script
    async crossorigin="anonymous"
    data-clerk-publishable-key="<%= ENV['CLERK_PUBLISHABLE_KEY'] %>"
    src="https://cdn.jsdelivr.net/npm/@clerk/clerk-js@5/dist/clerk.browser.js"
  ></script>
  <%= csrf_meta_tags %>
</head>
<body>
  <div class="app-shell">
    <%= render "shared/sidebar" %>
    <main class="app-main" id="main-content">
      <%= render "shared/flash" %>
      <%= render "layouts/demo_banner" %>
      <%= render "shared/connect_banner" %>
      <%= yield %>
    </main>
  </div>
  <%= javascript_include_tag "sidebar" %>
  <%= javascript_include_tag "toasts" %>
  <%= javascript_include_tag "agent-stream" %>
  <%= javascript_include_tag "settings" %>
</body>
</html>
