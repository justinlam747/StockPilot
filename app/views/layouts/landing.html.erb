<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>StockPilot — AI Inventory Agents for Shopify</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&display=swap" rel="stylesheet">
  <script
    async crossorigin="anonymous"
    data-clerk-publishable-key="<%= ENV['CLERK_PUBLISHABLE_KEY'] %>"
    src="https://cdn.jsdelivr.net/npm/@clerk/clerk-js@5/dist/clerk.browser.js"
  ></script>
  <%= csrf_meta_tags %>
  <%= stylesheet_link_tag "landing" %>
</head>
<body>
  <%= yield %>
  <%= javascript_include_tag "vision-tabs" %>
  <% if content_for?(:landing_scripts) %>
    <%= yield :landing_scripts %>
  <% end %>
</body>
</html>
