<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>stockpilot — AI Inventory Agents for Shopify</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <%= csrf_meta_tags %>
  <%= stylesheet_link_tag "landing" %>
  <%= stylesheet_link_tag "vision" if controller_name == 'vision' %>
</head>
<body class="<%= controller_name == 'landing' ? 'lp-body--hero' : 'lp-body--vision' %>">
  <%= yield %>
  <%= javascript_include_tag "vision-tabs" if controller_name == 'vision' %>
</body>
</html>
