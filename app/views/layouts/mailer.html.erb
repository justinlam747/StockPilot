<!DOCTYPE html>
<html lang="en">
  <head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>StockPilot</title>
    <style>
      body {
        margin: 0;
        padding: 0;
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
        font-size: 14px;
        line-height: 1.5;
        color: #1A1A1A;
        background-color: #F6F6F7;
        -webkit-font-smoothing: antialiased;
      }
      .email-wrapper {
        max-width: 600px;
        margin: 0 auto;
        padding: 32px 16px;
      }
      .email-card {
        background: #FFFFFF;
        border: 1px solid #E1E3E5;
        border-radius: 8px;
        padding: 32px;
      }
      .email-header {
        font-size: 13px;
        font-weight: 700;
        color: #1A1A1A;
        letter-spacing: -0.01em;
        padding-bottom: 16px;
        border-bottom: 1px solid #E1E3E5;
        margin-bottom: 24px;
      }
      .email-footer {
        margin-top: 24px;
        padding-top: 16px;
        border-top: 1px solid #E1E3E5;
        font-size: 13px;
        color: #6D7175;
      }
      h2 { font-size: 18px; font-weight: 600; color: #1A1A1A; margin: 0 0 8px; }
      h3 { font-size: 15px; font-weight: 600; color: #1A1A1A; margin: 20px 0 8px; }
      p { margin: 0 0 12px; }
      a { color: #2C6ECB; text-decoration: none; }
      a:hover { text-decoration: underline; }
      table { width: 100%; border-collapse: collapse; margin: 12px 0; }
      th {
        text-align: left;
        padding: 8px 12px;
        font-size: 12px;
        font-weight: 600;
        color: #6D7175;
        background: #F6F6F7;
        border-bottom: 1px solid #E1E3E5;
      }
      td {
        padding: 8px 12px;
        font-size: 14px;
        color: #1A1A1A;
        border-bottom: 1px solid #E1E3E5;
      }
      tr:nth-child(even) td { background: #F6F6F7; }
    </style>
  </head>
  <body>
    <div class="email-wrapper">
      <div class="email-card">
        <div class="email-header">StockPilot</div>
        <%= yield %>
        <div class="email-footer">
          This email was sent by StockPilot, your inventory intelligence assistant.
        </div>
      </div>
    </div>
  </body>
</html>
