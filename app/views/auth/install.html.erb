<div style="display: flex; justify-content: center; align-items: center; min-height: 80vh;">
  <div style="background: #fff; padding: 40px; border-radius: 8px; border: 1px solid #C9CCCF; text-align: center; max-width: 400px;">
    <h1 style="color: #1A1A1A; font-size: 24px; margin-bottom: 8px;">Install StockPilot</h1>
    <p style="color: #6D7175; margin-bottom: 24px;">Enter your Shopify store URL to connect.</p>
    <%= form_with url: "/auth/shopify", method: :post, data: { turbo: false } do |f| %>
      <%= text_field_tag :shop, "stockpilot-7.myshopify.com",
            placeholder: "your-store.myshopify.com",
            style: "width: 100%; padding: 10px; border: 1px solid #C9CCCF; border-radius: 6px; font-size: 14px; margin-bottom: 16px; box-sizing: border-box; color: #1A1A1A;" %>
      <%= submit_tag "Connect with Shopify",
            style: "background: #fff; border: 1px solid #C9CCCF; color: #6D7175; font-weight: 600; padding: 10px 24px; border-radius: 6px; cursor: pointer; font-size: 16px; width: 100%;" %>
    <% end %>
  </div>
</div>
