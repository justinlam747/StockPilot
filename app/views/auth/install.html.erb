<a href="#lp-main" class="sr-only">Skip to main content</a>

<!-- Sticky nav -->
<nav class="lp-nav" aria-label="StockPilot navigation">
  <div class="lp-nav__inner">
    <a href="/" class="lp-nav__brand" aria-label="StockPilot home">StockPilot</a>
  </div>
</nav>

<main id="lp-main">
  <section class="lp-install">
    <div class="lp-install__card">
      <h1 class="lp-install__title">Install StockPilot</h1>
      <p class="lp-install__subtitle">Enter your Shopify store URL to connect.</p>
      <%= form_with url: "/auth/shopify", method: :post, data: { turbo: false }, html: { aria: { label: "Connect your Shopify store" }, class: "lp-install__form" } do |f| %>
        <label for="shop-url" class="sr-only">Store URL</label>
        <%= text_field_tag :shop, "stockpilot-7.myshopify.com",
              id: "shop-url",
              placeholder: "your-store.myshopify.com",
              autocomplete: "url",
              class: "lp-install__input",
              "aria-label": "Your Shopify store URL" %>
        <%= submit_tag "Connect with Shopify",
              class: "lp-btn lp-install__submit",
              "aria-label": "Connect your Shopify store to StockPilot" %>
      <% end %>
    </div>
  </section>
</main>

<!-- Footer -->
<footer class="lp-footer">
  <div class="lp-footer__inner">
    <div class="lp-footer__left">
      <p>&copy; 2026 StockPilot</p>
    </div>
    <nav class="lp-footer__right" aria-label="Footer links">
      <a href="#">Privacy Policy</a>
      <a href="#">Terms of Service</a>
      <a href="#">Changelog</a>
    </nav>
  </div>
</footer>
