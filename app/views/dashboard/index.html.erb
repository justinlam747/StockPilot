<% if @show_connect_banner %>
  <div class="bento__tile" style="padding: var(--space-12) var(--space-6); text-align: center;">
    <div class="sp-empty">
      <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="var(--green-400)"
           stroke-width="1.5" stroke-linecap="round" aria-hidden="true" style="margin-bottom: var(--space-4);">
        <path d="M12 2v20"/>
        <path d="M5 7h14"/>
        <path d="M7 7l1 13h8l1-13"/>
      </svg>
      <p class="sp-empty__title">Connect a Shopify store</p>
      <p class="sp-empty__desc">Run one sync, then review catalog issues from the dashboard and issues page.</p>
      <div style="margin-top: var(--space-4); display: flex; gap: var(--space-3); justify-content: center; flex-wrap: wrap;">
        <a href="<%= settings_path %>" class="sp-btn">Connect store</a>
        <a href="<%= root_path %>" class="sp-btn sp-btn--sm">View product intro</a>
      </div>
    </div>
  </div>
<% else %>
  <div class="sp-page-header">
    <h1>Catalog Overview</h1>
    <p style="color: var(--color-text-secondary); margin-top: 6px;">
      Review the current catalog footprint, active issues, and last sync status.
    </p>
  </div>

  <div class="bento" role="list" aria-label="Catalog overview">
    <div class="bento__tile bento__tile--hero" role="listitem" style="grid-column: 1; grid-row: 1;">
      <div class="bento__tile-top">
        <span class="bento__tile-label">Products</span>
      </div>
      <div class="bento__content">
        <span class="bento__value"><%= @total_products %></span>
        <span class="bento__label">Products scanned</span>
      </div>
    </div>

    <div class="bento__tile" role="listitem" style="grid-column: 2; grid-row: 1;">
      <div class="bento__tile-top">
        <span class="bento__tile-label">Variants</span>
      </div>
      <div class="bento__content">
        <span class="bento__value"><%= @total_variants %></span>
        <span class="bento__label">Variants tracked</span>
      </div>
    </div>

    <a href="/issues" class="bento__tile bento__tile--warn" role="listitem" style="grid-column: 3; grid-row: 1;">
      <div class="bento__tile-top">
        <span class="bento__tile-label">Issues</span>
      </div>
      <div class="bento__content">
        <span class="bento__value"><%= @issue_count %></span>
        <span class="bento__label">Open issues</span>
        <span class="bento__sub"><%= @critical_issue_count %> critical, <%= @warning_issue_count %> warning</span>
      </div>
    </a>

    <div class="bento__tile" role="listitem" style="grid-column: 4; grid-row: 1;">
      <div class="bento__tile-top">
        <span class="bento__tile-label">Coverage</span>
      </div>
      <div class="bento__content">
        <span class="bento__value"><%= @catalog_coverage %>%</span>
        <span class="bento__label">Products without active issues</span>
      </div>
    </div>

    <div class="bento__tile" role="listitem" style="grid-column: 1 / span 2; grid-row: 2;">
      <div class="bento__tile-top">
        <span class="bento__tile-label">Sync</span>
      </div>
      <div class="bento__content">
        <span class="bento__title">Current catalog snapshot</span>
        <span class="bento__sub">
          <% if current_shop.synced_at.present? %>
            Last synced <%= time_ago_in_words(current_shop.synced_at) %> ago.
          <% else %>
            No sync completed yet.
          <% end %>
        </span>
        <form action="<%= sync_catalog_path %>" method="post" style="margin-top: 16px;">
          <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
          <button type="submit" class="bento__btn">Run sync</button>
        </form>
      </div>
    </div>

    <div class="bento__tile bento__tile--list" role="listitem" style="grid-column: 3 / span 2; grid-row: 2;">
      <div class="bento__tile-top">
        <span class="bento__tile-label">Recent issues</span>
      </div>
      <div class="bento__content" style="margin-top: var(--space-2); flex: 1;">
        <% if @recent_issues.any? %>
          <div class="bento__alert-list">
            <% @recent_issues.each do |issue| %>
              <div class="bento__alert-row bento__alert-row--<%= issue.severity || 'warning' %>">
                <span class="bento__alert-dot"></span>
                <div style="display: flex; flex-direction: column; min-width: 0;">
                  <span style="font-weight: 600;"><%= truncate("#{issue.title} - #{issue.product.title}", length: 56) %></span>
                  <span style="font-size: 12px; color: var(--color-text-secondary);">
                    <%= truncate(issue.detail, length: 72) %>
                  </span>
                </div>
                <span class="alert-severity--<%= issue.severity || 'warning' %>"><%= (issue.severity || 'warning').titleize %></span>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="sp-empty" style="padding: var(--space-4) 0; text-align: left;">
            <p class="sp-empty__title" style="margin-bottom: 4px;">Catalog looks clean</p>
            <p class="sp-empty__desc">Run sync after product changes to confirm the current scan stays clean.</p>
            <div style="margin-top: var(--space-4);">
              <%= form_with url: sync_catalog_path, method: :post, data: { turbo: false }, html: { style: 'display: inline-block;' } do %>
                <button type="submit" class="sp-btn sp-btn--sm">Run sync</button>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>
<% end %>
