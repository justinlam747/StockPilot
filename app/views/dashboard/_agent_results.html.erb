<% if results.present? %>
  <div class="agent-summary" data-agent-stream>
    <div class="agent-summary__stats">
      <div class="agent-stat">
        <span class="agent-stat__value"><%= results["low_stock_count"] || 0 %></span>
        <span class="agent-stat__label">Items flagged</span>
      </div>
      <div class="agent-stat">
        <span class="agent-stat__value"><%= results["turns"] || 1 %></span>
        <span class="agent-stat__label">Agent turns</span>
      </div>
      <div class="agent-stat">
        <span class="agent-stat__value"><%= results["ran_at"] ? Time.parse(results["ran_at"]).strftime("%H:%M") : "---" %></span>
        <span class="agent-stat__label">Completed</span>
      </div>
    </div>
    <% if results["provider"] || results["model"] %>
      <span class="agent-provider-badge">
        <%= h(results["provider"]&.capitalize || 'Anthropic') %><% if results["model"] %> &middot; <%= h(results["model"]) %><% end %>
      </span>
    <% end %>
    <% if results["fallback"] %>
      <span class="bento__sub" style="color: var(--color-warning);">Ran in fallback mode (AI unavailable)</span>
    <% end %>
    <% if results["error"] %>
      <span class="bento__sub" style="color: var(--color-warning);"><%= h(results["error"]) %></span>
    <% end %>
  </div>

  <% if results["log"].present? %>
    <details class="agent-log" open>
      <summary>Agent reasoning (<%= results["log"].size %> steps)</summary>
      <div class="agent-log__entries" data-agent-stream-entries>
        <% results["log"].each_with_index do |entry, i| %>
          <div class="agent-log__entry" data-stream-index="<%= i %>">
            <span class="agent-log__step"><%= i + 1 %></span>
            <span class="agent-log__text"><%= h(entry) %></span>
          </div>
        <% end %>
      </div>
    </details>
  <% end %>
<% else %>
  <span class="bento__meta">Run your first analysis to surface insights</span>
<% end %>
