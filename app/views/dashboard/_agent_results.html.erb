<% if results.present? %>
  <div class="sp-detail-grid">
    <div class="sp-detail-item">
      <span class="sp-detail-item__label">Last run</span>
      <span class="sp-detail-item__value"><%= results["ran_at"] || @last_run_at&.strftime("%b %d, %H:%M") %></span>
    </div>
    <div class="sp-detail-item">
      <span class="sp-detail-item__label">Low stock items found</span>
      <span class="sp-detail-item__value"><%= results["low_stock_count"] || 0 %></span>
    </div>
  </div>
<% else %>
  <div class="sp-empty">
    <p class="sp-empty__desc">No agent runs yet. Click "Run Agent Now" to start.</p>
  </div>
<% end %>
