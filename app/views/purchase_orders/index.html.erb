<div class="sp-page-header">
  <h1>Purchase Orders</h1>
  <div class="sp-page-header__actions">
    <button hx-post="/purchase_orders/generate_draft"
            hx-target="#draft-area"
            hx-indicator="#draft-spinner"
            class="sp-btn--primary"
            aria-label="Generate a draft purchase order using AI">
      Generate Draft PO
    </button>
    <span id="draft-spinner" class="htmx-indicator">
      <span class="sp-spinner" aria-hidden="true"></span>
      Generating with AI...
    </span>
  </div>
</div>

<div id="draft-area" aria-live="polite"></div>

<div id="po-list">
  <%= render "list", purchase_orders: @purchase_orders %>
</div>
