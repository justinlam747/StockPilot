<div class="po-header">
  <div class="po-header__top">
    <div>
      <h1 class="po-header__title">Purchase Orders</h1>
      <span class="po-header__count"><%= @purchase_orders.total_count %> order<%= @purchase_orders.total_count == 1 ? '' : 's' %></span>
    </div>
    <div class="po-header__actions">
      <a href="<%= new_purchase_order_path %>" class="bento__btn">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
             stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
        </svg>
        New Purchase Order
      </a>
    </div>
  </div>

  <div class="po-filters inv-filters">
    <span class="inv-filters__label">Status</span>
    <a href="<%= purchase_orders_path %>"
       class="inv-filter-btn <%= 'is-active' unless params[:status].present? %>"
       aria-label="Show all purchase orders">All</a>
    <a href="<%= purchase_orders_path(status: 'draft') %>"
       class="inv-filter-btn <%= 'is-active' if params[:status] == 'draft' %>">
      <span class="inv-filter-dot" style="background: var(--color-text-disabled);" aria-hidden="true"></span>
      Draft
    </a>
    <a href="<%= purchase_orders_path(status: 'sent') %>"
       class="inv-filter-btn <%= 'is-active' if params[:status] == 'sent' %>">
      <span class="inv-filter-dot inv-filter-dot--warn" aria-hidden="true"></span>
      Sent
    </a>
    <a href="<%= purchase_orders_path(status: 'received') %>"
       class="inv-filter-btn <%= 'is-active' if params[:status] == 'received' %>">
      <span class="inv-filter-dot" style="background: var(--green-500);" aria-hidden="true"></span>
      Received
    </a>
  </div>
</div>


<div id="po-list">
  <%= render "list", purchase_orders: @purchase_orders %>
</div>
