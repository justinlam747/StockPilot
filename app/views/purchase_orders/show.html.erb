<a href="/purchase_orders" class="sp-back-link" aria-label="Back to purchase orders list">
  &larr; Back to Purchase Orders
</a>

<div class="sp-page-header">
  <h1>Purchase Order #<%= @purchase_order.id %></h1>
  <div class="sp-page-header__actions">
    <% if @purchase_order.status == "draft" %>
      <%= button_to "Mark as Sent",
            mark_sent_purchase_order_path(@purchase_order),
            method: :patch,
            class: "sp-btn--primary",
            aria: { label: "Mark this purchase order as sent" } %>
    <% elsif @purchase_order.status == "sent" %>
      <%= button_to "Mark as Received",
            mark_received_purchase_order_path(@purchase_order),
            method: :patch,
            class: "sp-btn--primary",
            aria: { label: "Mark this purchase order as received" } %>
    <% end %>
  </div>
</div>

<div class="sp-card">
  <div class="sp-detail-grid">
    <div class="sp-detail-item">
      <span class="sp-detail-item__label">Supplier</span>
      <span class="sp-detail-item__value"><%= @purchase_order.supplier&.name || "N/A" %></span>
    </div>
    <div class="sp-detail-item">
      <span class="sp-detail-item__label">Status</span>
      <span class="sp-detail-item__value">
        <% status = @purchase_order.status %>
        <span class="sp-badge sp-badge--<%= status == 'draft' ? 'neutral' : status == 'sent' ? 'info' : 'success' %>">
          <%= status.capitalize %>
        </span>
      </span>
    </div>
    <div class="sp-detail-item">
      <span class="sp-detail-item__label">Created</span>
      <span class="sp-detail-item__value"><%= @purchase_order.created_at.strftime("%b %d, %Y %H:%M") %></span>
    </div>
    <% if @purchase_order.source == 'agent_action' %>
      <div class="sp-detail-item">
        <span class="sp-detail-item__label">Source</span>
        <span class="sp-detail-item__value">
          Generated from AI
          <% if @purchase_order.source_agent_run.present? %>
            &middot; <a href="<%= agent_path(@purchase_order.source_agent_run) %>">Agent Run #<%= @purchase_order.source_agent_run_id %></a>
          <% end %>
        </span>
      </div>
    <% end %>
  </div>
</div>

<% if @email_draft %>
  <section class="sp-section" aria-labelledby="email-draft-heading">
    <div class="sp-card">
      <h2 id="email-draft-heading" class="sp-card__title">Supplier email draft</h2>
      <div class="sp-detail-grid">
        <div class="sp-detail-item">
          <span class="sp-detail-item__label">To</span>
          <span class="sp-detail-item__value"><%= @email_draft.to %></span>
        </div>
        <div class="sp-detail-item">
          <span class="sp-detail-item__label">Subject</span>
          <span class="sp-detail-item__value"><%= @email_draft.subject %></span>
        </div>
      </div>
      <pre class="sp-email-draft" aria-label="Email body draft"><%= @email_draft.body %></pre>
    </div>
  </section>
<% end %>

<section class="sp-section" aria-labelledby="line-items-heading">
  <div class="sp-card">
    <h2 id="line-items-heading" class="sp-card__title">Line Items</h2>
    <table aria-label="Purchase order line items">
      <thead>
        <tr>
          <th scope="col">Variant</th>
          <th scope="col">Quantity</th>
          <th scope="col">Unit Cost</th>
        </tr>
      </thead>
      <tbody>
        <% @purchase_order.line_items.each do |li| %>
          <tr>
            <td><%= li.variant&.title || li.variant&.sku %></td>
            <td><%= li.qty_ordered %></td>
            <td><%= number_to_currency(li.unit_price) %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</section>
