<% if purchase_orders.any? %>
  <table>
    <thead>
      <tr>
        <th>PO Number</th>
        <th>Supplier</th>
        <th>Items</th>
        <th>Status</th>
        <th>Created</th>
        <th style="text-align: right;">Actions</th>
      </tr>
    </thead>
    <tbody>
      <% purchase_orders.each do |po| %>
        <tr>
          <td><a href="/purchase_orders/<%= po.id %>"><%= po.po_number || "##{po.id}" %></a></td>
          <td><%= po.supplier&.name %></td>
          <td class="text-secondary"><%= po.line_items.size %> items</td>
          <td>
            <% status_class = case po.status
                 when "draft" then "badge--neutral"
                 when "sent" then "badge--warning"
                 when "received" then "badge--success"
                 else "badge--neutral"
               end %>
            <span class="badge <%= status_class %>"><%= po.status.capitalize %></span>
          </td>
          <td class="text-secondary"><%= po.created_at.strftime("%b %d, %Y") %></td>
          <td style="text-align: right;">
            <a href="/purchase_orders/<%= po.id %>" class="btn btn--sm">View</a>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <%= render "shared/pagination", collection: purchase_orders %>
<% else %>
  <div class="empty-state">
    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="color: var(--app-text-3); margin-bottom: 0.5rem;"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
    <div>No purchase orders yet. Generate your first draft above.</div>
  </div>
<% end %>
