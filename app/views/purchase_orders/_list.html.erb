<% if purchase_orders.any? %>
  <div class="po-grid">
    <% purchase_orders.each do |po| %>
      <%
        status = po.status
        line_count = po.line_items.size
        total_value = po.line_items.sum { |li| (li.qty_ordered || 0) * (li.unit_price || 0) }
        status_class = case status
                       when 'draft' then 'neutral'
                       when 'sent' then 'warning'
                       when 'received' then 'success'
                       when 'cancelled' then 'critical'
                       else 'neutral'
                       end
      %>
      <a href="<%= purchase_order_path(po) %>" class="po-card bento__tile" aria-label="View purchase order #<%= po.id %>">
        <% if status == 'sent' %>
          <span class="bento__glow bento__glow--amber" style="width: 100px; height: 100px; top: -20px; right: -20px;" aria-hidden="true"></span>
        <% elsif status == 'received' %>
          <span class="bento__glow" style="width: 100px; height: 100px; top: -20px; right: -20px;" aria-hidden="true"></span>
        <% end %>

        <div class="po-card__top">
          <span class="po-card__number">#<%= po.id %></span>
          <span class="sp-badge sp-badge--<%= status_class %>"><%= status.capitalize %></span>
        </div>

        <div class="po-card__supplier">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
               stroke-width="2" stroke-linecap="round" aria-hidden="true">
            <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/>
            <circle cx="12" cy="7" r="4"/>
          </svg>
          <span><%= po.supplier&.name || 'No supplier' %></span>
        </div>

        <div class="po-card__details">
          <div class="po-card__detail">
            <span class="po-card__detail-label">Items</span>
            <span class="po-card__detail-value"><%= line_count %></span>
          </div>
          <div class="po-card__detail">
            <span class="po-card__detail-label">Value</span>
            <span class="po-card__detail-value po-card__detail-value--mono">
              $<%= number_with_precision(total_value, precision: 2, delimiter: ',') %>
            </span>
          </div>
        </div>

        <div class="po-card__dates">
          <span class="po-card__date">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                 stroke-width="2" stroke-linecap="round" aria-hidden="true">
              <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/>
              <line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
            </svg>
            Ordered <%= po.order_date&.strftime("%b %d, %Y") || po.created_at.strftime("%b %d, %Y") %>
          </span>
          <% if po.expected_delivery.present? %>
            <span class="po-card__date">
              Expected <%= po.expected_delivery.strftime("%b %d, %Y") %>
            </span>
          <% end %>
        </div>
      </a>
    <% end %>
  </div>

  <%= render "shared/pagination", collection: purchase_orders %>
<% else %>
  <div class="bento__tile" style="padding: var(--space-12) var(--space-6); text-align: center;">
    <div class="sp-empty">
      <p class="sp-empty__title">No purchase orders</p>
      <p class="sp-empty__desc">Generate a draft PO to get started.</p>
    </div>
  </div>
<% end %>
