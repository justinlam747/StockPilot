<div class="sp-draft-preview" aria-live="polite">
  <h3 class="sp-card__title">AI-Generated Draft</h3>
  <% if draft.present? %>
    <pre><%= draft.to_json %></pre>
  <% else %>
    <div class="sp-empty">
      <p class="sp-empty__desc">No draft could be generated. Check that you have low-stock items and suppliers configured.</p>
    </div>
  <% end %>
</div>
