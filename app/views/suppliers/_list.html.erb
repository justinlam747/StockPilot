<div id="supplier-list-inner">
  <% if suppliers.any? %>
    <div class="sup-grid">
      <% suppliers.each do |s| %>
        <div class="sup-card bento__tile" id="supplier-<%= s.id %>">
          <span class="bento__glow" style="width: 120px; height: 120px; top: -30px; right: -30px;" aria-hidden="true"></span>

          <div class="sup-card__top">
            <div class="sup-card__avatar" aria-hidden="true">
              <%= s.name.first(2).upcase %>
            </div>
            <div class="sup-card__identity">
              <span class="sup-card__name"><%= s.name %></span>
              <% if s.email.present? %>
                <a href="mailto:<%= s.email %>" class="sup-card__email"><%= s.email %></a>
              <% end %>
            </div>
          </div>

          <div class="sup-card__details">
            <% if s.phone.present? %>
              <div class="sup-card__detail">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                     stroke-width="2" stroke-linecap="round" aria-hidden="true">
                  <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6
                           19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7
                           2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339
                           1.85.573 2.81.7A2 2 0 0122 16.92z"/>
                </svg>
                <span><%= s.phone %></span>
              </div>
            <% end %>

            <div class="sup-card__detail">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                   stroke-width="2" stroke-linecap="round" aria-hidden="true">
                <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
              </svg>
              <span><%= s.lead_time_days || '—' %> day<%= s.lead_time_days == 1 ? '' : 's' %> lead time</span>
            </div>

            <div class="sup-card__detail">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                   stroke-width="2" stroke-linecap="round" aria-hidden="true">
                <path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0
                         001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/>
              </svg>
              <span><%= s.variants.size %> linked variant<%= s.variants.size == 1 ? '' : 's' %></span>
            </div>
          </div>

          <div class="sup-card__rating">
            <span class="star-rating"
                  role="group"
                  aria-label="Rating for <%= s.name %>: <%= s.star_rating || 0 %> out of 5 stars">
              <% 5.times do |i| %>
                <span hx-patch="<%= supplier_path(s) %>"
                      hx-vals='{"supplier": {"star_rating": <%= i + 1 %>}}'
                      hx-target="#supplier-list"
                      role="button"
                      tabindex="0"
                      aria-label="Rate <%= s.name %> <%= i + 1 %> star<%= i + 1 > 1 ? 's' : '' %>"
                      class="<%= i < (s.star_rating || 0) ? 'filled' : 'empty' %>">&#9733;</span>
              <% end %>
            </span>
          </div>

          <div class="sup-card__actions">
            <button hx-delete="<%= supplier_path(s) %>"
                    hx-target="#supplier-list"
                    hx-confirm="Delete <%= s.name %>?"
                    class="sp-btn--destructive sp-btn--sm"
                    aria-label="Delete supplier <%= s.name %>">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                   stroke-width="2" stroke-linecap="round" aria-hidden="true">
                <polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 01-2 2H7a2 2 0
                         01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2"/>
              </svg>
              Delete
            </button>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="bento__tile" style="padding: var(--space-12) var(--space-6); text-align: center;">
      <div class="sp-empty">
        <p class="sp-empty__title">No suppliers yet</p>
        <p class="sp-empty__desc">Add your first supplier using the form above.</p>
      </div>
    </div>
  <% end %>
</div>
