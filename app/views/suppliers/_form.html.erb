<form hx-post="<%= url %>"
      hx-target="#supplier-list"
      hx-swap="innerHTML"
      aria-label="Supplier form">
  <%= hidden_field_tag :authenticity_token, form_authenticity_token %>

  <div class="sp-form-group">
    <label for="supplier-name">Name</label>
    <input type="text"
           id="supplier-name"
           name="supplier[name]"
           value="<%= supplier.name %>"
           required
           autocomplete="organization"
           aria-required="true">
  </div>

  <div class="sp-form-group">
    <label for="supplier-email">Email</label>
    <input type="email"
           id="supplier-email"
           name="supplier[email]"
           value="<%= supplier.email %>"
           required
           autocomplete="email"
           aria-required="true">
  </div>

  <div class="sp-form-group">
    <label for="supplier-phone">Phone</label>
    <input type="tel"
           id="supplier-phone"
           name="supplier[phone]"
           value="<%= supplier.phone %>"
           autocomplete="tel">
  </div>

  <div class="sp-form-group">
    <label for="supplier-lead-time">Lead Time (days)</label>
    <input type="number"
           id="supplier-lead-time"
           name="supplier[lead_time_days]"
           value="<%= supplier.lead_time_days %>"
           min="1"
           aria-describedby="lead-time-hint">
    <span id="lead-time-hint" class="text-secondary" style="font-size: var(--font-size-sm); margin-top: var(--space-1); display: block;">
      Average number of days from order to delivery
    </span>
  </div>

  <button type="submit" class="sp-btn--primary" aria-label="Save supplier">
    Save Supplier
  </button>
</form>
