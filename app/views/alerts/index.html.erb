<div class="sp-page-header">
  <h1>Alerts</h1>
</div>

<% if @alerts.any? %>
  <div class="sp-card">
    <table aria-label="Inventory alerts">
      <thead>
        <tr>
          <th scope="col">Severity</th>
          <th scope="col">Message</th>
          <th scope="col">Created</th>
          <th scope="col">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @alerts.each do |alert| %>
          <tr id="alert-<%= alert.id %>">
            <td>
              <span class="sp-badge sp-badge--<%= alert.severity == 'critical' ? 'critical' : 'warning' %>">
                <%= (alert.severity || "warning").capitalize %>
              </span>
            </td>
            <td><%= alert.message %></td>
            <td><%= alert.created_at.strftime("%b %d, %Y %H:%M") %></td>
            <td>
              <% unless alert.dismissed? %>
                <button hx-patch="<%= dismiss_alert_path(alert) %>"
                        hx-target="#alert-<%= alert.id %>"
                        hx-swap="outerHTML"
                        class="sp-btn--sm"
                        aria-label="Dismiss alert: <%= alert.message %>">
                  Dismiss
                </button>
              <% else %>
                <span class="text-secondary">Dismissed</span>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <%= render "shared/pagination", collection: @alerts %>
<% else %>
  <div class="sp-card">
    <div class="sp-empty">
      <p class="sp-empty__title">No alerts</p>
      <p class="sp-empty__desc">No alerts to display. Your inventory is looking good.</p>
    </div>
  </div>
<% end %>
