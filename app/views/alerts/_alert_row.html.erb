<div class="alt-row alert-row--<%= issue.severity %>" id="issue-<%= issue.fingerprint %>">
  <div class="alt-row__dot alt-row__dot--<%= issue.severity %>" aria-hidden="true"></div>
  <div class="alt-row__body">
    <span class="alt-row__message"><%= issue.title %> - <%= issue.product.title %></span>
    <span class="alt-row__time"><%= issue.detail %></span>
  </div>
  <div class="alt-row__actions">
    <span class="alert-severity--<%= issue.severity %>"><%= issue.severity.titleize %></span>
    <% if issue.variant&.sku.present? %>
      <span class="alt-row__dismissed">SKU <%= issue.variant.sku %></span>
    <% end %>
    <a href="<%= issue.admin_url %>" class="alt-row__dismiss" target="_blank" rel="noopener noreferrer" aria-label="Open <%= issue.product.title %> in Shopify">
      Open in Shopify
    </a>
  </div>
</div>
