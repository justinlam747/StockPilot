<div class="imp-header">
  <h1 class="imp-header__title">Import Inventory</h1>
  <p class="imp-header__sub">Upload a CSV or paste inventory data. We'll detect the columns automatically.</p>
</div>

<div class="sp-card">
  <div class="imp-tabs" role="tablist" aria-label="Import method">
    <button type="button"
            class="imp-tab is-active"
            role="tab"
            aria-selected="true"
            aria-controls="tab-paste"
            id="tab-btn-paste"
            onclick="switchTab('paste')">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/>
        <rect x="8" y="2" width="8" height="4" rx="1" ry="1"/>
      </svg>
      Paste Data
    </button>
    <button type="button"
            class="imp-tab"
            role="tab"
            aria-selected="false"
            aria-controls="tab-csv"
            id="tab-btn-csv"
            onclick="switchTab('csv')">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
        <polyline points="14 2 14 8 20 8"/>
        <line x1="16" y1="13" x2="8" y2="13"/>
        <line x1="16" y1="17" x2="8" y2="17"/>
      </svg>
      Upload CSV
    </button>
  </div>

  <%# Paste tab %>
  <div id="tab-paste" role="tabpanel" aria-labelledby="tab-btn-paste" class="imp-panel">
    <%= form_tag imports_path, method: :post do %>
      <div class="sp-form-group">
        <label for="raw_text">Inventory data</label>
        <textarea id="raw_text"
                  name="raw_text"
                  rows="12"
                  placeholder="Paste your inventory data here &#8212; we'll figure out the columns.

Example:
SKU          Product Name        Qty    Price
ABC-001      Widget Pro          150    29.99
DEF-002      Gadget Plus         42     14.50
GHI-003      Super Sprocket      0      8.75"
                  aria-describedby="paste-help"></textarea>
        <p id="paste-help" class="imp-help">
          Tab-separated, comma-separated, or pipe-separated data. Headers are detected automatically.
        </p>
      </div>
      <div class="imp-actions">
        <button type="submit" class="sp-btn sp-btn--primary">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="22 12 16 12 14 15 10 15 8 12 2 12"/>
            <path d="M5.45 5.11L2 12v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-6l-3.45-6.89A2 2 0 0 0 16.76 4H7.24a2 2 0 0 0-1.79 1.11z"/>
          </svg>
          Parse &amp; Preview
        </button>
        <a href="/imports" class="sp-btn">View Import History</a>
      </div>
    <% end %>
  </div>

  <%# CSV tab %>
  <div id="tab-csv" role="tabpanel" aria-labelledby="tab-btn-csv" class="imp-panel" hidden>
    <%= form_tag imports_path, method: :post, multipart: true do %>
      <div class="sp-form-group">
        <label for="csv_file">CSV file</label>
        <div class="imp-dropzone" id="dropzone">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="imp-dropzone__icon">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
            <polyline points="17 8 12 3 7 8"/>
            <line x1="12" y1="3" x2="12" y2="15"/>
          </svg>
          <p class="imp-dropzone__text">Drag and drop a CSV file, or click to browse</p>
          <p class="imp-dropzone__hint">Supports .csv files with headers</p>
          <input type="file"
                 id="csv_file"
                 name="file"
                 accept=".csv,text/csv"
                 class="imp-dropzone__input"
                 aria-describedby="csv-help">
        </div>
        <p id="csv-help" class="imp-help">
          First row should contain column headers (SKU, Name, Quantity, Price, etc.)
        </p>
      </div>
      <div class="imp-actions">
        <button type="submit" class="sp-btn sp-btn--primary">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="22 12 16 12 14 15 10 15 8 12 2 12"/>
            <path d="M5.45 5.11L2 12v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-6l-3.45-6.89A2 2 0 0 0 16.76 4H7.24a2 2 0 0 0-1.79 1.11z"/>
          </svg>
          Parse &amp; Preview
        </button>
        <a href="/imports" class="sp-btn">View Import History</a>
      </div>
    <% end %>
  </div>
</div>

<script>
  function switchTab(tab) {
    document.querySelectorAll('.imp-tab').forEach(function(btn) {
      btn.classList.remove('is-active');
      btn.setAttribute('aria-selected', 'false');
    });
    document.querySelectorAll('.imp-panel').forEach(function(panel) {
      panel.hidden = true;
    });
    document.getElementById('tab-btn-' + tab).classList.add('is-active');
    document.getElementById('tab-btn-' + tab).setAttribute('aria-selected', 'true');
    document.getElementById('tab-' + tab).hidden = false;
  }
</script>
