<div class="imp-header">
  <h1 class="imp-header__title">Preview Import</h1>
  <p class="imp-header__sub">
    <%= @rows.size %> rows detected from
    <span class="sp-badge sp-badge--neutral"><%= @import.source.upcase %></span>
    input. Assign each column below, then confirm.
  </p>
</div>

<%= form_tag confirm_import_path(@import), method: :post do %>
  <div class="sp-card">
    <div class="imp-preview-scroll">
      <table class="imp-preview-table" aria-label="Import data preview">
        <thead>
          <tr>
            <th scope="col" class="imp-preview-rownum">#</th>
            <% col_count = @rows.any? ? @rows.map(&:size).max : 0 %>
            <% col_count.times do |i| %>
              <th scope="col">
                <% if @headers %>
                  <span class="imp-col-header"><%= @headers[i] %></span>
                <% end %>
                <select name="mapping[<%= i %>]"
                        class="imp-col-select"
                        aria-label="Column <%= i + 1 %> mapping">
                  <option value="">Ignore</option>
                  <option value="sku" <%= 'selected' if @mapping[i.to_s] == 'sku' %>>SKU</option>
                  <option value="title" <%= 'selected' if @mapping[i.to_s] == 'title' %>>Product Name</option>
                  <option value="quantity" <%= 'selected' if @mapping[i.to_s] == 'quantity' %>>Quantity</option>
                  <option value="price" <%= 'selected' if @mapping[i.to_s] == 'price' %>>Price</option>
                  <option value="supplier" <%= 'selected' if @mapping[i.to_s] == 'supplier' %>>Supplier</option>
                </select>
              </th>
            <% end %>
          </tr>
        </thead>
        <tbody>
          <% @rows.first(20).each_with_index do |row, idx| %>
            <tr>
              <td class="imp-preview-rownum"><%= idx + 1 %></td>
              <% col_count.times do |i| %>
                <td><%= row[i] %></td>
              <% end %>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <% if @rows.size > 20 %>
      <p class="imp-preview-note">
        Showing first 20 of <%= @rows.size %> rows.
      </p>
    <% end %>
  </div>

  <div class="imp-actions imp-actions--sticky">
    <button type="submit" class="sp-btn sp-btn--primary">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <polyline points="20 6 9 17 4 12"/>
      </svg>
      Confirm Import (<%= @rows.size %> rows)
    </button>
    <a href="<%= new_import_path %>" class="sp-btn">Start Over</a>
  </div>
<% end %>
