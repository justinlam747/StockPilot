<nav class="sidebar" aria-label="Main navigation">
  <div class="sidebar__brand">
    <%= image_tag "stockpilot-icon.png", alt: "StockPilot", class: "sidebar__icon" %>
  </div>

  <ul class="sidebar__menu">
    <li>
      <a href="/dashboard" class="sidebar__link <%= 'is-active' if request.path == '/dashboard' %>">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/>
        </svg>
        Dashboard
      </a>
    </li>
    <li>
      <a href="/inventory" class="sidebar__link <%= 'is-active' if request.path.start_with?('/inventory') %>">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/>
        </svg>
        Inventory
      </a>
    </li>
    <li>
      <a href="/suppliers" class="sidebar__link <%= 'is-active' if request.path.start_with?('/suppliers') %>">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/>
        </svg>
        Suppliers
      </a>
    </li>
    <li>
      <a href="/purchase_orders" class="sidebar__link <%= 'is-active' if request.path.start_with?('/purchase_orders') %>">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/>
        </svg>
        Purchase Orders
      </a>
    </li>
    <li>
      <a href="/alerts" class="sidebar__link <%= 'is-active' if request.path.start_with?('/alerts') %>">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 01-3.46 0"/>
        </svg>
        Alerts
      </a>
    </li>
  </ul>

  <div class="sidebar__footer">
    <div class="sidebar__user">
      <div class="sidebar__avatar">
        <%= current_shop&.shop_domain&.first&.upcase || "S" %>
      </div>
      <span class="sidebar__user-name"><%= current_shop&.shop_domain&.split(".")&.first&.titleize || "My Store" %></span>
    </div>
    <%= button_to "Logout", "/logout", method: :delete, class: "sidebar__logout" %>
  </div>
</nav>
