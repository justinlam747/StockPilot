<nav class="sidebar" aria-label="Main navigation" id="sidebar" data-expanded="false">
  <button class="sidebar__mobile-toggle" id="sidebar-mobile-open"
          aria-label="Open navigation menu" aria-expanded="false"
          aria-controls="sidebar-drawer">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
      <path d="M4 6h16M4 12h16M4 18h16"/>
    </svg>
  </button>

  <div class="sidebar__desktop" id="sidebar-desktop">
    <div class="sidebar__brand">
      <svg width="22" height="22" viewBox="0 0 28 28" fill="none" aria-hidden="true" class="sidebar__logo">
        <rect x="2" y="2" width="24" height="24" rx="6" stroke="currentColor" stroke-width="1.5"/>
        <path d="M8 19h12M8 14h12M8 9h8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
      <span class="sidebar__brand-text">Catalog Audit</span>
    </div>

    <ul role="list" class="sidebar__nav">
      <li>
        <a href="/dashboard"
           class="sidebar__link <%= 'active' if request.path == '/dashboard' %>"
           aria-current="<%= 'page' if request.path == '/dashboard' %>"
           data-tooltip="Dashboard">
          <span class="sidebar__label">Dashboard</span>
        </a>
      </li>
      <li>
        <a href="/issues"
           class="sidebar__link <%= 'active' if request.path.start_with?('/issues') %>"
           aria-current="<%= 'page' if request.path.start_with?('/issues') %>"
           data-tooltip="Issues">
          <span class="sidebar__label">Issues</span>
        </a>
      </li>
      <li>
        <a href="/settings"
           class="sidebar__link <%= 'active' if request.path.start_with?('/settings') %>"
           aria-current="<%= 'page' if request.path.start_with?('/settings') %>"
           data-tooltip="Settings">
          <span class="sidebar__label">Settings</span>
        </a>
      </li>
    </ul>

    <div class="sidebar__footer">
      <div class="sidebar__user">
        <div class="sidebar__avatar" aria-hidden="true">
          <span><%= current_shop&.shop_domain&.first&.upcase || 'S' %></span>
        </div>
        <div class="sidebar__user-info sidebar__label">
          <span class="sidebar__user-name"><%= current_shop&.shop_domain || 'No shop connected' %></span>
          <span class="sidebar__logout-link">Catalog quality review</span>
        </div>
      </div>
    </div>
  </div>

  <div class="sidebar__overlay" id="sidebar-overlay"></div>

  <div class="sidebar__drawer" id="sidebar-drawer" aria-hidden="true">
    <div class="sidebar__drawer-header">
      <div class="sidebar__brand">
        <svg width="22" height="22" viewBox="0 0 28 28" fill="none" aria-hidden="true">
          <rect x="2" y="2" width="24" height="24" rx="6" stroke="currentColor" stroke-width="1.5"/>
          <path d="M8 19h12M8 14h12M8 9h8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
        <span class="sidebar__brand-text">Catalog Audit</span>
      </div>
      <button class="sidebar__drawer-close" id="sidebar-mobile-close"
              aria-label="Close navigation menu">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
          <path d="M18 6L6 18M6 6l12 12"/>
        </svg>
      </button>
    </div>

    <ul role="list" class="sidebar__nav">
      <li><a href="/dashboard" class="sidebar__link <%= 'active' if request.path == '/dashboard' %>"><span>Dashboard</span></a></li>
      <li><a href="/issues" class="sidebar__link <%= 'active' if request.path.start_with?('/issues') %>"><span>Issues</span></a></li>
      <li><a href="/settings" class="sidebar__link <%= 'active' if request.path.start_with?('/settings') %>"><span>Settings</span></a></li>
    </ul>
  </div>
</nav>
