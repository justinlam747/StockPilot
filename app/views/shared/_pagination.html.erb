<% if collection.respond_to?(:total_pages) && collection.total_pages > 1 %>
  <nav class="sp-pagination" aria-label="Pagination">
    <% if collection.prev_page %>
      <%= link_to url_for(page: collection.prev_page),
            class: "sp-btn sp-btn--sm",
            aria: { label: "Go to previous page" } do %>
        &larr; Previous
      <% end %>
    <% end %>
    <span class="sp-pagination__info" aria-current="page">
      Page <%= collection.current_page %> of <%= collection.total_pages %>
    </span>
    <% if collection.next_page %>
      <%= link_to url_for(page: collection.next_page),
            class: "sp-btn sp-btn--sm",
            aria: { label: "Go to next page" } do %>
        Next &rarr;
      <% end %>
    <% end %>
  </nav>
<% end %>
