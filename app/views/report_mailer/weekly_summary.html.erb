<h2>Weekly Inventory Report — <%= @report.shop.shop_domain %></h2>
<p>Week of <%= @report.week_start.strftime('%B %d, %Y') %></p>

<h3>Top Sellers</h3>
<% if @payload["top_sellers"].present? %>
  <table border="1" cellpadding="8" cellspacing="0" style="border-collapse: collapse; width: 100%;">
    <thead>
      <tr style="background: #F6F6F7;">
        <th>SKU</th>
        <th>Product</th>
        <th>Units Sold</th>
      </tr>
    </thead>
    <tbody>
      <% @payload["top_sellers"].each do |item| %>
        <tr>
          <td><%= item["sku"] %></td>
          <td><%= item["title"] %></td>
          <td><%= item["units_sold"] %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p>No sales data available for this period.</p>
<% end %>

<h3>Stockout Events: <%= @payload["stockouts"]&.size || 0 %></h3>
<h3>Low Stock SKUs: <%= @payload["low_sku_count"] || 0 %></h3>

<% if @payload["reorder_suggestions"].present? %>
  <h3>Reorder Suggestions</h3>
  <% @payload["reorder_suggestions"].each do |suggestion| %>
    <p><strong><%= suggestion["supplier_name"] %></strong></p>
    <ul>
      <% (suggestion["items"] || []).each do |item| %>
        <li><%= item["sku"] %> — suggest ordering <%= item["suggested_qty"] %> units</li>
      <% end %>
    </ul>
  <% end %>
<% end %>

<% if @payload["ai_commentary"].present? %>
  <h3>AI Insights</h3>
  <p><%= @payload["ai_commentary"] %></p>
<% end %>

<p style="margin-top: 16px; color: #6D7175;">
  Generated by Inventory Intelligence.
</p>
