<h2>Weekly Inventory Report</h2>
<p><strong><%= @shop.shop_domain %></strong> &mdash; Week of <%= Date.current.strftime('%B %d, %Y') %></p>

<h3>Top Sellers</h3>
<% if @report["top_sellers"].present? %>
  <table>
    <thead>
      <tr>
        <th>SKU</th>
        <th>Product</th>
        <th>Units Sold</th>
      </tr>
    </thead>
    <tbody>
      <% @report["top_sellers"].each do |item| %>
        <tr>
          <td><%= item["sku"] %></td>
          <td><%= item["title"] %></td>
          <td><%= item["units_sold"] %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p>No sales data available for this period.</p>
<% end %>

<h3>Stockout Events: <%= @report["stockouts"]&.size || 0 %></h3>
<h3>Low Stock SKUs: <%= @report["low_sku_count"] || 0 %></h3>

<% if @report["reorder_suggestions"].present? %>
  <h3>Reorder Suggestions</h3>
  <% @report["reorder_suggestions"].each do |suggestion| %>
    <p><strong><%= suggestion["supplier_name"] %></strong></p>
    <ul>
      <% (suggestion["items"] || []).each do |item| %>
        <li><%= item["sku"] %> &mdash; suggest ordering <%= item["suggested_qty"] %> units</li>
      <% end %>
    </ul>
  <% end %>
<% end %>

<p style="margin-top: 16px; color: #6D7175; font-size: 13px;">
  Generated by StockPilot, your inventory intelligence assistant.
</p>
