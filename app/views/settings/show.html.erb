<div class="sp-page-header">
  <h1>Settings</h1>
</div>

<%= form_with url: '/settings', method: :patch, data: { turbo: false }, html: { class: 'settings-form' } do %>

  <!-- AI Provider -->
  <section class="settings-section">
    <div class="settings-section__header">
      <h2 class="settings-section__title">AI Provider</h2>
      <p class="settings-section__desc">Choose which AI model powers your inventory agent, insights, and purchase order drafts.</p>
    </div>

    <div class="settings-card bento__tile">
      <div class="settings-row">
        <div class="settings-field">
          <label for="llm_provider" class="settings-label">Provider</label>
          <select name="llm_provider" id="llm_provider" class="settings-select" onchange="updateModelOptions()">
            <option value="openai" <%= 'selected' if current_shop.llm_provider == 'openai' %>>OpenAI</option>
            <option value="anthropic" <%= 'selected' if current_shop.llm_provider == 'anthropic' %>>Anthropic (Claude)</option>
            <option value="google" <%= 'selected' if current_shop.llm_provider == 'google' %>>Google (Gemini)</option>
          </select>
        </div>

        <div class="settings-field">
          <label for="llm_model" class="settings-label">Model</label>
          <select name="llm_model" id="llm_model" class="settings-select" data-initial="<%= current_shop.llm_model %>">
          </select>
        </div>
      </div>

      <div class="settings-divider"></div>

      <div class="settings-row">
        <div class="settings-field settings-field--full">
          <label for="openai_api_key" class="settings-label">
            OpenAI API Key
            <% if current_shop.settings['openai_api_key'].present? %>
              <span class="settings-connected">Connected</span>
            <% end %>
          </label>
          <input type="password"
                 name="openai_api_key"
                 id="openai_api_key"
                 class="settings-input settings-input--key"
                 placeholder="sk-..."
                 value="<%= current_shop.settings['openai_api_key'].present? ? '••••••••' + current_shop.settings['openai_api_key'].last(4) : '' %>"
                 autocomplete="off">
          <span class="settings-hint">Get your key from <a href="https://platform.openai.com/api-keys" target="_blank" rel="noopener">platform.openai.com</a></span>
        </div>
      </div>

      <div class="settings-row">
        <div class="settings-field settings-field--full">
          <label for="anthropic_api_key" class="settings-label">
            Anthropic API Key
            <% if current_shop.settings['anthropic_api_key'].present? %>
              <span class="settings-connected">Connected</span>
            <% end %>
          </label>
          <input type="password"
                 name="anthropic_api_key"
                 id="anthropic_api_key"
                 class="settings-input settings-input--key"
                 placeholder="sk-ant-..."
                 value="<%= current_shop.settings['anthropic_api_key'].present? ? '••••••••' + current_shop.settings['anthropic_api_key'].last(4) : '' %>"
                 autocomplete="off">
          <span class="settings-hint">Get your key from <a href="https://console.anthropic.com/" target="_blank" rel="noopener">console.anthropic.com</a></span>
        </div>
      </div>

      <div class="settings-row">
        <div class="settings-field settings-field--full">
          <label for="google_api_key" class="settings-label">
            Google API Key
            <% if current_shop.settings['google_api_key'].present? %>
              <span class="settings-connected">Connected</span>
            <% end %>
          </label>
          <input type="password"
                 name="google_api_key"
                 id="google_api_key"
                 class="settings-input settings-input--key"
                 placeholder="AI..."
                 value="<%= current_shop.settings['google_api_key'].present? ? '••••••••' + current_shop.settings['google_api_key'].last(4) : '' %>"
                 autocomplete="off">
          <span class="settings-hint">Get your key from <a href="https://aistudio.google.com/apikey" target="_blank" rel="noopener">aistudio.google.com</a></span>
        </div>
      </div>
    </div>
  </section>

  <!-- Inventory -->
  <section class="settings-section">
    <div class="settings-section__header">
      <h2 class="settings-section__title">Inventory</h2>
      <p class="settings-section__desc">Configure stock thresholds and alert behavior.</p>
    </div>

    <div class="settings-card bento__tile">
      <div class="settings-row">
        <div class="settings-field">
          <label for="low_stock_threshold" class="settings-label">Default Low Stock Threshold</label>
          <input type="number"
                 name="low_stock_threshold"
                 id="low_stock_threshold"
                 class="settings-input"
                 value="<%= current_shop.low_stock_threshold %>"
                 min="1" max="1000">
          <span class="settings-hint">Variants below this quantity trigger low-stock alerts. Can be overridden per variant.</span>
        </div>

        <div class="settings-field">
          <label for="timezone" class="settings-label">Timezone</label>
          <select name="timezone" id="timezone" class="settings-select">
            <% ActiveSupport::TimeZone.all.each do |tz| %>
              <option value="<%= tz.name %>" <%= 'selected' if current_shop.timezone == tz.name %>><%= tz.to_s %></option>
            <% end %>
          </select>
          <span class="settings-hint">Used for weekly report scheduling and alert timestamps.</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Notifications -->
  <section class="settings-section">
    <div class="settings-section__header">
      <h2 class="settings-section__title">Notifications</h2>
      <p class="settings-section__desc">Where to send alerts and reports.</p>
    </div>

    <div class="settings-card bento__tile">
      <div class="settings-row">
        <div class="settings-field settings-field--full">
          <label for="alert_email" class="settings-label">Alert Email</label>
          <input type="email"
                 name="alert_email"
                 id="alert_email"
                 class="settings-input"
                 placeholder="you@example.com"
                 value="<%= current_shop.alert_email %>">
          <span class="settings-hint">Low-stock alerts and weekly reports are sent to this address.</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Save -->
  <div class="settings-actions">
    <button type="submit" class="bento__btn settings-save">Save Settings</button>
    <div id="settings-notice"></div>
  </div>

<% end %>
