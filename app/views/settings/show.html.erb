<div class="sp-page-header">
  <h1>Settings</h1>
</div>

<%= form_with url: '/settings', method: :patch, data: { turbo: false }, html: { class: 'settings-form' } do %>

  <!-- Inventory -->
  <section class="settings-section">
    <div class="settings-section__header">
      <h2 class="settings-section__title">Inventory</h2>
      <p class="settings-section__desc">Configure stock thresholds and alert behavior.</p>
    </div>

    <div class="settings-card bento__tile">
      <div class="settings-row">
        <div class="settings-field">
          <label for="low_stock_threshold" class="settings-label">Default Low Stock Threshold</label>
          <input type="number"
                 name="low_stock_threshold"
                 id="low_stock_threshold"
                 class="settings-input"
                 value="<%= current_shop.low_stock_threshold %>"
                 min="1" max="1000">
          <span class="settings-hint">Variants below this quantity trigger low-stock alerts. Can be overridden per variant.</span>
        </div>

        <div class="settings-field">
          <label for="timezone" class="settings-label">Timezone</label>
          <select name="timezone" id="timezone" class="settings-select">
            <% ActiveSupport::TimeZone.all.each do |tz| %>
              <option value="<%= tz.name %>" <%= 'selected' if current_shop.timezone == tz.name %>><%= tz.to_s %></option>
            <% end %>
          </select>
          <span class="settings-hint">Used for weekly report scheduling and alert timestamps.</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Notifications -->
  <section class="settings-section">
    <div class="settings-section__header">
      <h2 class="settings-section__title">Notifications</h2>
      <p class="settings-section__desc">Where to send alerts and reports.</p>
    </div>

    <div class="settings-card bento__tile">
      <div class="settings-row">
        <div class="settings-field settings-field--full">
          <label for="alert_email" class="settings-label">Alert Email</label>
          <input type="email"
                 name="alert_email"
                 id="alert_email"
                 class="settings-input"
                 placeholder="you@example.com"
                 value="<%= current_shop.alert_email %>">
          <span class="settings-hint">Low-stock alerts and weekly reports are sent to this address.</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Save -->
  <div class="settings-actions">
    <button type="submit" class="bento__btn settings-save">Save Settings</button>
    <div id="settings-notice"></div>
  </div>

<% end %>
