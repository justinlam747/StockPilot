<div class="sp-page-header">
  <h1>Settings</h1>
</div>

<% if current_shop.present? %>
<%= form_with url: '/settings', method: :patch, data: { turbo: false }, html: { class: 'settings-form' } do %>

  <section class="settings-section">
    <div class="settings-section__header">
      <h2 class="settings-section__title">Store</h2>
      <p class="settings-section__desc">Keep the app focused on one workflow: connect, sync, review issues.</p>
    </div>

    <div class="settings-card bento__tile">
      <div class="settings-row">
        <div class="settings-field">
          <label class="settings-label">Connected shop</label>
          <input type="text"
                 class="settings-input"
                 value="<%= current_shop.shop_domain %>"
                 readonly>
          <span class="settings-hint">This store is the current tenant for catalog scans.</span>
        </div>

        <div class="settings-field">
          <label for="timezone" class="settings-label">Timezone</label>
          <select name="timezone" id="timezone" class="settings-select">
            <% ActiveSupport::TimeZone.all.each do |tz| %>
              <option value="<%= tz.name %>" <%= 'selected' if current_shop.timezone == tz.name %>><%= tz.to_s %></option>
            <% end %>
          </select>
          <span class="settings-hint">Used for timestamps in the catalog review UI.</span>
        </div>
      </div>
    </div>
  </section>

  <section class="settings-section">
    <div class="settings-section__header">
      <h2 class="settings-section__title">Sync</h2>
      <p class="settings-section__desc">Keep the product lean: one sync path, one review surface.</p>
    </div>

    <div class="settings-card bento__tile">
      <div class="settings-row">
        <div class="settings-field settings-field--full">
          <label class="settings-label">Last sync</label>
          <input type="text"
                 class="settings-input"
                 value="<%= current_shop.synced_at.present? ? time_ago_in_words(current_shop.synced_at) + ' ago' : 'Not synced yet' %>"
                 readonly>
          <span class="settings-hint">Use the dashboard to run a new sync and refresh the issue list.</span>
        </div>
      </div>
    </div>
  </section>

  <div class="settings-actions">
    <button type="submit" class="bento__btn settings-save">Save Settings</button>
    <div id="settings-notice"></div>
  </div>

<% end %>
<% else %>
  <div class="settings-section">
    <div class="settings-section__header">
      <h2 class="settings-section__title">Connect your store</h2>
      <p class="settings-section__desc">Start with one store connection, then run a sync and review the audit results.</p>
    </div>

    <div class="settings-card bento__tile">
      <%= form_with url: shopify_connect_path, method: :post, data: { turbo: false } do %>
        <div class="settings-row">
          <div class="settings-field settings-field--full">
            <label for="shop_domain" class="settings-label">Shop domain</label>
            <input type="text"
                   name="shop_domain"
                   id="shop_domain"
                   class="settings-input"
                   placeholder="your-store or your-store.myshopify.com">
            <span class="settings-hint">Use your myshopify domain. The app will start the Shopify OAuth flow.</span>
          </div>
        </div>
        <div class="settings-actions">
          <button type="submit" class="bento__btn settings-save">Connect Shopify store</button>
        </div>
      <% end %>
    </div>
  </div>
<% end %>
