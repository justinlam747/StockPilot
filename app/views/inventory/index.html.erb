<div class="inv-header">
  <div class="inv-header__top">
    <div>
      <h1 class="inv-header__title">Inventory</h1>
      <span class="inv-header__count"><%= @products.total_count %> products &middot; <%= @total_variants %> SKUs</span>
    </div>
    <div class="inv-header__actions">
      <div class="inv-view-toggle" role="group" aria-label="View mode">
        <a href="/inventory?view=grid&filter=<%= params[:filter] %>&q=<%= params[:q] %>&sort=<%= params[:sort] %>"
           class="inv-view-btn <%= 'is-active' unless params[:view] == 'table' %>"
           aria-label="Grid view" title="Grid view">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
        </a>
        <a href="/inventory?view=table&filter=<%= params[:filter] %>&q=<%= params[:q] %>&sort=<%= params[:sort] %>"
           class="inv-view-btn <%= 'is-active' if params[:view] == 'table' %>"
           aria-label="Table view" title="Table view">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
        </a>
      </div>
    </div>
  </div>

  <div class="inv-toolbar">
    <div class="inv-toolbar__left">
      <div class="sp-search inv-search">
        <svg class="sp-search__icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
        <label for="inventory-search" class="sr-only">Search products</label>
        <input type="search"
               id="inventory-search"
               name="q"
               placeholder="Search by name, SKU, or vendor..."
               value="<%= params[:q] %>"
               hx-get="/inventory"
               hx-target="#product-list"
               hx-trigger="input changed delay:300ms"
               hx-push-url="true"
               hx-vals='{"view": "<%= params[:view] %>", "filter": "<%= params[:filter] %>", "sort": "<%= params[:sort] %>"}'
               aria-label="Search inventory">
      </div>

      <div class="inv-filters" role="group" aria-label="Filter inventory">
        <span class="inv-filters__label">Status</span>
        <a href="/inventory?filter=all&view=<%= params[:view] %>&q=<%= params[:q] %>&sort=<%= params[:sort] %>"
           class="inv-filter-btn <%= 'is-active' if params[:filter].blank? || params[:filter] == 'all' %>">
          All (<%= @healthy_products + @low_stock + @out_of_stock %>)
        </a>
        <a href="/inventory?filter=low_stock&view=<%= params[:view] %>&q=<%= params[:q] %>&sort=<%= params[:sort] %>"
           class="inv-filter-btn inv-filter-btn--warn <%= 'is-active' if params[:filter] == 'low_stock' %>">
          <span class="inv-filter-dot inv-filter-dot--warn"></span>
          Low Stock (<%= @low_stock %>)
        </a>
        <a href="/inventory?filter=out_of_stock&view=<%= params[:view] %>&q=<%= params[:q] %>&sort=<%= params[:sort] %>"
           class="inv-filter-btn inv-filter-btn--danger <%= 'is-active' if params[:filter] == 'out_of_stock' %>">
          <span class="inv-filter-dot inv-filter-dot--danger"></span>
          Out of Stock (<%= @out_of_stock %>)
        </a>
      </div>
    </div>

    <div class="inv-toolbar__right">
      <div class="inv-sort">
        <label for="inv-sort-select" class="inv-sort__label">Sort by</label>
        <select id="inv-sort-select"
                class="inv-sort__select"
                onchange="window.location.href='/inventory?sort='+this.value+'&view=<%= params[:view] %>&filter=<%= params[:filter] %>&q=<%= params[:q] %>'"
                name="sort">
          <option value="title" <%= 'selected' if params[:sort].blank? || params[:sort] == 'title' %>>Name A–Z</option>
          <option value="title_desc" <%= 'selected' if params[:sort] == 'title_desc' %>>Name Z–A</option>
          <option value="newest" <%= 'selected' if params[:sort] == 'newest' %>>Newest</option>
          <option value="vendor" <%= 'selected' if params[:sort] == 'vendor' %>>Vendor</option>
        </select>
      </div>
    </div>
  </div>

  <div class="inv-stats">
    <div class="inv-stat">
      <span class="inv-stat__dot inv-stat__dot--green"></span>
      <span><%= @healthy_products %> healthy</span>
    </div>
    <div class="inv-stat">
      <span class="inv-stat__dot inv-stat__dot--amber"></span>
      <span><%= @low_stock %> low stock</span>
    </div>
    <div class="inv-stat">
      <span class="inv-stat__dot inv-stat__dot--red"></span>
      <span><%= @out_of_stock %> out of stock</span>
    </div>
  </div>
</div>

<div id="product-list">
  <% if params[:view] == 'table' %>
    <%= render "table", products: @products %>
  <% else %>
    <%= render "grid", products: @products %>
  <% end %>
</div>
