<div class="inv-grid">
  <% products.each do |product| %>
    <% qty = product.variants.first&.current_stock || 0 %>
    <% variant_count = product.variants.size %>
    <a href="/inventory/<%= product.id %>" class="inv-card">
      <div class="inv-card__img">
        <div class="inv-card__skeleton" aria-hidden="true"></div>
        <% if product.image_url.present? %>
          <img src="<%= product.image_url %>"
               alt="<%= product.title %>"
               loading="lazy"
               onerror="this.style.display='none'">
        <% end %>
        <% if qty == 0 %>
          <span class="inv-card__badge inv-card__badge--critical">Out of Stock</span>
        <% elsif qty <= (product.variants.first&.low_stock_threshold || 10) %>
          <span class="inv-card__badge inv-card__badge--warning">Low Stock</span>
        <% end %>
      </div>
      <div class="inv-card__body">
        <% if product.product_type.present? %>
          <span class="inv-card__type"><%= product.product_type %></span>
        <% end %>
        <span class="inv-card__title"><%= product.title %></span>
        <span class="inv-card__variant"><%= variant_count %> variant<%= 's' if variant_count != 1 %></span>
        <div class="inv-card__footer">
          <span class="inv-card__stock"><%= qty %> in stock</span>
          <% if product.variants.first&.price.present? %>
            <span class="inv-card__price">$<%= product.variants.first.price.to_i %></span>
          <% end %>
        </div>
      </div>
    </a>
  <% end %>
</div>

<%= render "shared/pagination", collection: products %>
