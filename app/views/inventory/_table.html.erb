<% filter = local_assigns[:filter] || "all" %>
<table>
  <thead>
    <tr>
      <th>Product</th>
      <th>Variant</th>
      <th>SKU</th>
      <th style="text-align: right;">Stock</th>
      <th>Status</th>
    </tr>
  </thead>
  <tbody>
    <% products.each do |product| %>
      <% product.variants.each do |variant| %>
        <% qty = variant.inventory_quantity %>
        <% next if filter == "low_stock" && !(qty.between?(1, 10)) %>
        <% next if filter == "out_of_stock" && qty != 0 %>
        <tr>
          <td><a href="/inventory/<%= product.id %>"><%= product.title %></a></td>
          <td class="text-secondary"><%= variant.title %></td>
          <td><code class="sku-code"><%= variant.sku %></code></td>
          <td style="text-align: right; font-variant-numeric: tabular-nums;"><%= qty %></td>
          <td>
            <% if qty == 0 %>
              <span class="badge badge--danger">Out of Stock</span>
            <% elsif qty <= 10 %>
              <span class="badge badge--warning">Low Stock</span>
            <% else %>
              <span class="badge badge--success">In Stock</span>
            <% end %>
          </td>
        </tr>
      <% end %>
    <% end %>
  </tbody>
</table>

<%= render "shared/pagination", collection: products %>
