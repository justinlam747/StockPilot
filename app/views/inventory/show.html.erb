<a href="/inventory" class="sp-back-link" aria-label="Back to inventory list">
  &larr; Back to inventory
</a>

<div class="sp-page-header">
  <h1><%= @product.title %></h1>
</div>

<div class="sp-card">
  <table aria-label="Variants for <%= @product.title %>">
    <thead>
      <tr>
        <th scope="col">Variant</th>
        <th scope="col">SKU</th>
        <th scope="col">Stock</th>
        <th scope="col">Status</th>
      </tr>
    </thead>
    <tbody>
      <% @product.variants.each do |v| %>
        <% snapshot = v.inventory_snapshots.order(created_at: :desc).first %>
        <% qty = snapshot&.available || 0 %>
        <tr>
          <td><%= v.title %></td>
          <td><%= v.sku.presence || '—' %></td>
          <td><%= qty %></td>
          <td>
            <% if qty == 0 %>
              <span class="sp-badge sp-badge--critical">Out of Stock</span>
            <% elsif qty <= (v.low_stock_threshold || 10) %>
              <span class="sp-badge sp-badge--warning">Low</span>
            <% else %>
              <span class="sp-badge sp-badge--success">In Stock</span>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
