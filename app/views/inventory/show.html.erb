<a href="<%= inventory_index_path %>" class="sp-back-link" aria-label="Back to inventory list">
  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
       stroke-width="2" stroke-linecap="round" aria-hidden="true">
    <line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/>
  </svg>
  Back to inventory
</a>

<div class="pdp-header">
  <div class="pdp-header__info">
    <h1 class="pdp-header__title"><%= @product.title %></h1>
    <div class="pdp-header__meta">
      <% if @product.vendor.present? %>
        <span class="pdp-meta"><%= @product.vendor %></span>
      <% end %>
      <% if @product.product_type.present? %>
        <span class="pdp-meta"><%= @product.product_type %></span>
      <% end %>
      <% if @product.respond_to?(:status) && @product.status.present? %>
        <span class="sp-badge sp-badge--<%= @product.status == 'active' ? 'success' : 'neutral' %>">
          <%= @product.status&.capitalize %>
        </span>
      <% end %>
    </div>
  </div>
</div>

<div class="pdp-grid">
  <%# Product image card %>
  <div class="pdp-image-card bento__tile">
    <% if @product.respond_to?(:image_url) && @product.image_url.present? %>
      <img src="<%= @product.image_url %>" alt="<%= @product.title %>" class="pdp-image">
    <% else %>
      <div class="pdp-image-placeholder" aria-hidden="true">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--color-stroke)"
             stroke-width="1.5" stroke-linecap="round">
          <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
          <circle cx="8.5" cy="8.5" r="1.5"/>
          <polyline points="21 15 16 10 5 21"/>
        </svg>
      </div>
    <% end %>
  </div>

  <%# Stock chart card %>
  <div class="pdp-chart-card bento__tile">
    <span class="bento__glow" style="width: 160px; height: 160px; bottom: -40px; right: -40px;" aria-hidden="true"></span>
    <h2 class="pdp-section-title">Stock History (14 days)</h2>
    <% if @snapshot_data.present? && @snapshot_data.any? { |_d, v| v > 0 } %>
      <div class="pdp-chart" role="img" aria-label="Stock level chart for the last 14 days">
        <% max_val = [@snapshot_data.values.max, 1].max %>
        <div class="pdp-chart__bars">
          <% @snapshot_data.each do |date, qty| %>
            <% pct = (qty.to_f / max_val * 100).round %>
            <div class="pdp-chart__col">
              <div class="pdp-chart__bar-wrap">
                <div class="pdp-chart__bar"
                     style="height: <%= pct %>%;"
                     aria-label="<%= date.strftime('%b %d') %>: <%= qty %> units"
                     title="<%= date.strftime('%b %d') %>: <%= qty %> units">
                  <span class="pdp-chart__tooltip"><%= qty %></span>
                </div>
              </div>
              <span class="pdp-chart__label"><%= date.strftime('%d') %></span>
            </div>
          <% end %>
        </div>
      </div>
    <% else %>
      <div class="pdp-chart-empty">
        <p class="sp-empty__desc">No snapshot data available yet.</p>
      </div>
    <% end %>
  </div>
</div>

<%# Variants table %>
<div class="pdp-variants bento__tile">
  <span class="bento__glow" style="width: 200px; height: 200px; top: -60px; left: -60px;" aria-hidden="true"></span>
  <h2 class="pdp-section-title">
    Variants
    <span class="pdp-section-count"><%= @product.variants.size %></span>
  </h2>
  <table aria-label="Variants for <%= @product.title %>">
    <thead>
      <tr>
        <th scope="col">Variant</th>
        <th scope="col">SKU</th>
        <th scope="col">Stock</th>
        <th scope="col">Threshold</th>
        <th scope="col">Supplier</th>
        <th scope="col">Status</th>
      </tr>
    </thead>
    <tbody>
      <% @product.variants.each do |v| %>
        <% snapshot = v.inventory_snapshots.max_by(&:created_at) %>
        <% qty = snapshot&.available || 0 %>
        <tr>
          <td><strong><%= v.title %></strong></td>
          <td><code class="pdp-sku"><%= v.sku.presence || '---' %></code></td>
          <td>
            <span class="pdp-stock-value"><%= qty %></span>
          </td>
          <td><%= v.low_stock_threshold || '10' %></td>
          <td><%= v.supplier&.name || '---' %></td>
          <td>
            <% if qty == 0 %>
              <span class="sp-badge sp-badge--critical">Out of Stock</span>
            <% elsif qty <= (v.low_stock_threshold || 10) %>
              <span class="sp-badge sp-badge--warning">Low</span>
            <% else %>
              <span class="sp-badge sp-badge--success">In Stock</span>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
