# Shopify
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_APP_URL=

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/stockpilot_development
DATABASE_URL_TEST=postgresql://postgres:postgres@localhost:5432/stockpilot_test

# Redis
REDIS_URL=redis://localhost:6379/0

# Email (SendGrid for production, letter_opener for dev)
SENDGRID_API_KEY=
MAIL_FROM=noreply@example.com

# AI Providers (optional — SummaryClient falls back to deterministic text when blank)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
AI_PROVIDER=disabled

# Rails
SECRET_KEY_BASE=
RAILS_MASTER_KEY=
RAILS_ENV=development

# Sentry (optional)
SENTRY_DSN=
