# Shopify App Credentials
SHOPIFY_API_KEY=your_api_key
SHOPIFY_API_SECRET=your_api_secret
SHOPIFY_APP_URL=https://app.yourdomain.com

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/shopify_inventory_development

# Redis
REDIS_URL=redis://localhost:6379/0

# Email
MAIL_FROM=noreply@yourdomain.com

# Rails
SECRET_KEY_BASE=generate_with_bundle_exec_rails_secret
RAILS_MASTER_KEY=generate_with_rails_credentials_edit
RAILS_ENV=development

# Sentry (optional — error tracking)
SENTRY_DSN=

# AI (optional — operator summaries)
AI_PROVIDER=disabled
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=https://api.openai.com/v1
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
